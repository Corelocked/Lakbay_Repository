<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Map View -->
    <org.osmdroid.views.MapView
            android:id="@+id/map"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    <!-- Copyright Notice -->
    <TextView
        android:id="@+id/osm_copyright"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/osm_copyright"
        android:textSize="10sp"
        android:textColor="?android:attr/textColorSecondary"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="8dp" />

    <!-- Wrapper: input card + ETA/distance overlay stacked vertically -->
    <LinearLayout
        android:id="@+id/top_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:layout_margin="12dp">

    <!-- Input Card - Collapsible with cleaner design -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/card_background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header with collapse button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="@color/lakbay_red"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/plan_your_journey"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_settings"
                    android:layout_width="48dp"
                    android:layout_height="40dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:text="⚙"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:backgroundTint="#FF8C8C"
                    app:cornerRadius="20dp"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_collapse"
                    android:layout_width="48dp"
                    android:layout_height="40dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:text="▼"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:backgroundTint="#FF8C8C"
                    app:cornerRadius="20dp"
                    style="@style/Widget.Material3.Button.IconButton" />
            </LinearLayout>

            <!-- Collapsible content -->
            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fillViewport="true"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/collapsible_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp"
                    android:visibility="visible">

                    <!-- Start Location -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_start"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/start_hint"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="@color/lakbay_yellow"
                        app:startIconDrawable="@android:drawable/ic_menu_mylocation"
                        app:startIconTint="@color/primary"
                        app:endIconMode="clear_text"
                        app:hintTextColor="@color/black"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/et_start"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPostalAddress"
                            android:textSize="15sp"
                            android:completionThreshold="2"
                            android:dropDownHeight="wrap_content"
                            android:maxLines="1"
                            android:autofillHints="postalAddress" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Destination -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_destination"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/destination_hint"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="@color/lakbay_yellow"
                        app:startIconDrawable="@android:drawable/ic_dialog_map"
                        app:startIconTint="@color/accent"
                        app:endIconMode="clear_text"
                        app:hintTextColor="@color/black"
                        android:layout_marginBottom="16dp">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/et_destination"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            style="@style/Widget.App.AutoCompleteTextView.Popup"
                            android:inputType="textPostalAddress"
                            android:textSize="15sp"
                            android:completionThreshold="2"
                            android:dropDownHeight="wrap_content"
                            android:maxLines="1"
                            android:autofillHints="postalAddress" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_seeing"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:hint="@string/seeing_hint"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="@color/lakbay_yellow"
                        app:hintTextColor="@color/black">

                        <AutoCompleteTextView
                            android:id="@+id/actv_seeing"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            style="@style/Widget.App.AutoCompleteTextView.Popup"
                            android:inputType="none"
                            android:entries="@array/seeing_options"
                            />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_activity"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:hint="@string/activity_hint"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="@color/lakbay_yellow"
                        app:hintTextColor="@color/black">

                        <AutoCompleteTextView
                            android:id="@+id/actv_activity"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            style="@style/Widget.App.AutoCompleteTextView.Popup"
                            android:inputType="none"
                            android:entries="@array/activity_options"
                            />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Plan Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_plan"
                        style="@style/Widget.App.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:backgroundTint="@color/lakbay_red"
                        android:text="@string/plan_trip"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:icon="@android:drawable/ic_menu_directions"
                        app:iconGravity="textStart"
                        app:iconTint="@color/white" />

                    <!-- Progress Bar -->
                    <ProgressBar
                        android:id="@+id/progress_geocoding"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <!-- Routing phase progress -->
                    <ProgressBar
                        android:id="@+id/progress_routing"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:visibility="gone" />

                    <!-- POI fetching phase progress -->
                    <ProgressBar
                        android:id="@+id/progress_poi_fetch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:visibility="gone" />

                    <!-- Status Text -->
                    <TextView
                        android:id="@+id/tv_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:textAlignment="center"
                        android:visibility="gone"
                        tools:text="Planning your scenic route..."
                        tools:visibility="visible" />

                    <!-- POI preview (horizontal) -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_poi_previews"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:layout_marginTop="12dp"
                        android:clipToPadding="false"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:visibility="gone"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_poi_preview_horizontal" />
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ETA / Distance overlay card: shown only when the input card is collapsed -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/legend_overlay_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@android:color/white"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <!-- Distance -->
            <ImageView
                android:id="@+id/iv_overlay_distance_icon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_pin_red"
                android:contentDescription="@string/overlay_distance_icon_desc"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tv_overlay_distance"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/overlay_distance_placeholder"
                android:textSize="13sp"
                android:textColor="@color/text_primary" />

            <!-- ETA -->
            <ImageView
                android:id="@+id/iv_overlay_eta_icon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_user_arrow"
                android:contentDescription="@string/overlay_eta_icon_desc"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tv_overlay_eta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/overlay_eta_placeholder"
                android:textSize="13sp"
                android:textColor="@color/text_primary" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Full-screen progress overlay (blocks interactions while loading) -->
    <FrameLayout
        android:id="@+id/progress_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlay_dark"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardCornerRadius="20dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="32dp"
                android:gravity="center"
                android:minWidth="200dp">

                <ProgressBar
                    android:id="@+id/progress_overlay_spinner"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:indeterminate="true"
                    android:indeterminateTint="@color/primary" />

                <TextView
                    android:id="@+id/tv_overlay_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textAlignment="center"
                    android:text="@string/planning_route" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

    <!-- Center / follow user button (shown when user pans the map) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_center"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:layout_gravity="bottom|end"
        android:visibility="gone"
        android:contentDescription="@string/center_on_user"
        android:src="@android:drawable/ic_menu_mylocation"
        app:backgroundTint="@color/primary"
        app:tint="@color/white"    />

    <!-- End Route button: appears above the center button so it doesn't overlap -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_end_route"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="88dp"
        android:layout_gravity="bottom|end"
        android:visibility="gone"
        android:contentDescription="End route"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:backgroundTint="@color/lakbay_red"
        app:tint="@color/white" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
